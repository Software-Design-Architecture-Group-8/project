@startuml Prettier_System_Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_TOP_DOWN()
LAYOUT_WITH_LEGEND()

title System Context Diagram - Prettier Code Formatter

Person(developer, "Developer / Development Team", "Writes source code and triggers formatting via terminal commands (prettier --write) or automated editor extensions on file save.")

System(prettier_system, "Prettier", "An opinionated code formatter. Accepts raw source files, enforces a consistent visual style, and rewrites them according to configured rules.")

System_Ext(external_parsers, "Third-Party Parsers", "External libraries (Babel, PostCSS, TypeScript ESTree) that Prettier calls to convert raw source text into Abstract Syntax Trees.")
System_Ext(local_files, "Local File System", "The developer's disk. Prettier reads raw source files from here and writes the reformatted output back to the same location.")
System_Ext(cicd_pipeline, "CI/CD Pipeline", "Automated runners (e.g. GitHub Actions) that execute prettier --check and use the returned exit code to approve or block deployments.")

Rel(developer, prettier_system, "Triggers formatting on", "CLI / editor hook")
Rel(cicd_pipeline, prettier_system, "Triggers format check and receives exit code from", "CLI / OS Shell Process")
Rel(prettier_system, external_parsers, "Requests Abstract Syntax Trees from")
Rel(prettier_system, local_files, "Reads source files from and writes formatted output to", "Disk I/O")

@enduml